{% include "../partials/head.twig" with { title: title } %}
{% include "../partials/header.twig" %}
{% include "../partials/flash.twig" with { flash: flash, error: null, errors: [] } %}

<main class="shell page">
  <section class="section-header">
    <div>
      <span class="eyebrow">Mis reservas</span>
      <h1>Mis reservas</h1>
      <p>Vista del usuario estándar para consultar y cancelar solo sus propias reservas.</p>
    </div>
  </section>

  <section class="surface surface--filter">
    <form class="filter-bar" action="/reservations/mine" method="get">
      <div class="form__group">
        <label for="status">Estado</label>
        <select id="status" name="status">
          <option value="">Todos</option>
          <option value="ACTIVA" {% if statusFilter == 'ACTIVA' %}selected{% endif %}>ACTIVA</option>
          <option value="CANCELADA" {% if statusFilter == 'CANCELADA' %}selected{% endif %}>CANCELADA</option>
        </select>
      </div>
      <div class="filter-bar__actions">
        <button class="button button--primary" type="submit">Filtrar</button>
        <a class="button button--ghost" href="/reservations/mine">Limpiar</a>
      </div>
    </form>
  </section>

  <section class="surface">
    <table class="table">
      <thead>
        <tr>
          <th>Espacio</th>
          <th>Inicio</th>
          <th>Fin</th>
          <th>Estado</th>
          <th>Acción</th>
        </tr>
      </thead>
      <tbody>
        {% for reservation in reservations %}
          <tr>
            <td>{{ reservation.space.name }}</td>
            <td>{{ format_date_time(reservation.startAt) }}</td>
            <td>{{ format_date_time(reservation.endAt) }}</td>
            <td><span class="badge {% if reservation.status != 'ACTIVA' %}badge--neutral{% endif %}">{{ reservation.status }}</span></td>
            <td>
              {% if reservation.status == 'ACTIVA' %}
                <form action="/reservations/{{ reservation._id }}/cancel" method="post">
                  <button class="button button--ghost button--small" type="submit">Cancelar</button>
                </form>
              {% else %}
                <span class="muted">Sin acción</span>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>
</main>

{% include "../partials/footer.twig" %}
