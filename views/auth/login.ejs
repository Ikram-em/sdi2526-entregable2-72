<%- include("../partials/head", { title }) %>
<%- include("../partials/header") %>
<%- include("../partials/flash", { flash, error, errors: [] }) %>

<main class="shell page page--auth">
  <section class="auth-panel auth-panel--wide">
    <div class="auth-panel__intro">
      <span class="eyebrow">W2 · Inicio de sesion</span>
      <h1>Accede a la gestion de reservas</h1>
      <p>Introduce tu DNI y tu contrasena. El acceso de administrador redirige al listado global de reservas; el usuario estandar entra al listado de espacios activos.</p>
      <div class="credential-card">
        <strong>Credenciales admin de prueba</strong>
        <span>DNI: 12345678Z</span>
        <span>Password: @Dm1n1str@D0r</span>
      </div>
    </div>

    <form class="surface form" action="/login" method="post" data-validate="login" novalidate>
      <div class="form__group">
        <label for="dni">DNI</label>
        <input id="dni" name="dni" type="text" maxlength="9" value="<%= formData?.dni || '' %>" placeholder="12345678Z" />
        <small class="field-error" data-error-for="dni"></small>
      </div>

      <div class="form__group">
        <label for="password">Contrasena</label>
        <input id="password" name="password" type="password" placeholder="Tu contrasena" />
        <small class="field-error" data-error-for="password"></small>
      </div>

      <button class="button button--primary button--block" type="submit">Entrar</button>
      <p class="form__hint">Si aun no tienes cuenta, completa el registro de usuario estandar.</p>
      <a class="text-link" href="/register">Ir al registro</a>
    </form>
  </section>
</main>

<%- include("../partials/footer") %>
