<%- include("../partials/head", { title }) %>
<%- include("../partials/header") %>
<%- include("../partials/flash", { flash, error: null, errors: [] }) %>

<main class="shell page">
  <section class="page-hero">
    <div>
      <span class="eyebrow">Cuenta personal</span>
      <h1>Mi perfil</h1>
      <p>Consulta tus datos de acceso y la información principal de tu cuenta en una sola vista.</p>
    </div>
    <div class="hero-kpis">
      <article class="kpi-card">
        <span><%= metrics.primaryLabel %></span>
        <strong><%= metrics.primaryValue %></strong>
      </article>
      <article class="kpi-card">
        <span><%= metrics.secondaryLabel %></span>
        <strong><%= metrics.secondaryValue %></strong>
      </article>
    </div>
  </section>

  <section class="profile-grid">
    <article class="surface profile-card profile-card--main">
      <div class="profile-card__header">
        <div class="profile-avatar profile-avatar--large">
          <%= `${profile.firstName.charAt(0)}${profile.lastName.charAt(0)}` %>
        </div>
        <div>
          <h2><%= `${profile.firstName} ${profile.lastName}` %></h2>
          <p class="muted">Perfil <%= profile.role === "admin" ? "administrador" : "de usuario estándar" %></p>
        </div>
      </div>

      <dl class="profile-list">
        <div>
          <dt>DNI</dt>
          <dd><%= profile.dni %></dd>
        </div>
        <div>
          <dt>Nombre</dt>
          <dd><%= profile.firstName %></dd>
        </div>
        <div>
          <dt>Apellidos</dt>
          <dd><%= profile.lastName %></dd>
        </div>
        <div>
          <dt>Rol</dt>
          <dd><%= profile.role === "admin" ? "Administrador" : "Usuario estándar" %></dd>
        </div>
      </dl>
    </article>

    <article class="surface profile-card">
      <h2>Resumen de cuenta</h2>
      <dl class="profile-list">
        <div>
          <dt>Alta en el sistema</dt>
          <dd><%= formatDateTime(profile.createdAt) %></dd>
        </div>
        <div>
          <dt>Última actualización</dt>
          <dd><%= formatDateTime(profile.updatedAt) %></dd>
        </div>
        <div>
          <dt>Área principal</dt>
          <dd><%= profile.role === "admin" ? "Administración y control global" : "Consulta y gestión de espacios" %></dd>
        </div>
      </dl>

      <div class="profile-actions">
        <% if (profile.role === "standard") { %>
          <a class="button button--primary" href="/account/password">Actualizar contraseña</a>
          <a class="button button--ghost" href="/spaces">Ver espacios</a>
        <% } else { %>
          <a class="button button--primary" href="/admin/reservations">Ver reservas</a>
          <a class="button button--ghost" href="/admin/spaces">Gestionar espacios</a>
        <% } %>
      </div>
    </article>
  </section>
</main>

<%- include("../partials/footer") %>
