{% include "../../partials/head.twig" with { title: title } %}
{% include "../../partials/header.twig" %}
{% include "../../partials/flash.twig" with { flash: flash, error: null, errors: [] } %}

<main class="shell page">
  <section class="section-header">
    <div>
      <span class="eyebrow">Usuarios</span>
      <h1>Listado de usuarios</h1>
      <p>Vista paginada de usuarios del sistema, incluyendo el administrador y los usuarios estándar.</p>
    </div>
  </section>

  <section class="surface">
    <table class="table">
      <thead>
        <tr>
          <th>DNI</th>
          <th>Nombre</th>
          <th>Apellidos</th>
          <th>Rol</th>
        </tr>
      </thead>
      <tbody>
        {% for user in users %}
          <tr>
            <td>{{ user.dni }}</td>
            <td>{{ user.firstName }}</td>
            <td>{{ user.lastName }}</td>
            <td><span class="badge {% if user.role != 'admin' %}badge--neutral{% endif %}">{{ user.role }}</span></td>
          </tr>
        {% endfor %}
      </tbody>
    </table>

    <div class="pagination">
      {% if pagination.hasPrevious %}
        <a class="button button--ghost button--small" href="{{ buildPageLink(pagination.page - 1) }}">Anterior</a>
      {% endif %}
      <span class="pagination__status">Página {{ pagination.page }} de {{ pagination.totalPages }}</span>
      {% if pagination.hasNext %}
        <a class="button button--ghost button--small" href="{{ buildPageLink(pagination.page + 1) }}">Siguiente</a>
      {% endif %}
    </div>
  </section>
</main>

{% include "../../partials/footer.twig" %}
